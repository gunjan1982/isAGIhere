# Copy this file to .env.local for local development.
# Do not commit real secrets to source control.

# GCP project and service settings
PROJECT_ID=
REGION=asia-south1
SERVICE_NAME=isagihere
SQL_INSTANCE=PROJECT_ID:asia-south1:isagihere-db

# Database connection
# Local example: postgresql://isagihere_app:StrongPassword123!@127.0.0.1:5432/isagihere
# Cloud Run example: postgresql://isagihere_app:StrongPassword123!@/isagihere?cloudSqlInstance=PROJECT_ID:us-west1:isagihere-db
# Direct public IP example (less secure): postgresql://isagihere_app:StrongPassword123!@34.105.114.40:5432/isagihere
DATABASE_URL=

# Anthropic API key is required for interview summarization / AI summaries
ANTHROPIC_API_KEY=

# Clerk backend secret key for user auth and admin routes
CLERK_SECRET_KEY=

# Resend API key for transactional emails
RESEND_API_KEY=

# Frontend Clerk config
VITE_CLERK_PUBLISHABLE_KEY=
VITE_CLERK_PROXY_URL=

# Build/runtime settings
BASE_PATH=/
PORT=5173
LOG_LEVEL=info
NODE_ENV=production
